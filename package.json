{
  "name": "@dbhq/spreadsheet-health-check",
  "version": "0.0.0",
  "description": "Free, client-side spreadsheet risk scanner. Scores a workbook for business risk - key-person dependency, hidden fragility, live errors, scale limits. No upload.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/spreadsheet-health-check.mjs",
  "module": "./dist/spreadsheet-health-check.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "browser",
    "examples",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "fixtures": "node --experimental-strip-types test/fixtures/generate.mts",
    "scores": "vitest run test/calibration.test.ts",
    "build": "tsup",
    "demo": "node --experimental-strip-types demo/cli.mts",
    "check:iife": "node scripts/check-iife-bundle.mjs",
    "check:worker": "node scripts/check-worker-bundle.mjs",
    "example": "node --experimental-strip-types examples/generate-example.mts"
  },
  "dependencies": {
    "fflate": "0.8.3",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "8.5.1",
    "typescript": "^5.6.0",
    "vitest": "4.1.10"
  }
}
